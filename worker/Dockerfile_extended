FROM python:3.14-slim

WORKDIR /app

ENV PYTHONUNBUFFERED=1

COPY requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY worker_dfs.py ./worker.py
COPY templates ./templates

RUN mkdir -p /app/datanode_storage

EXPOSE 5000

HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
  CMD ["python", "-c", "import json, urllib.request; response = urllib.request.urlopen('http://127.0.0.1:5000/health', timeout=5); payload = json.load(response); raise SystemExit(0 if payload.get('status') == 'ok' else 1)"]

CMD ["waitress-serve", "--port=5000", "worker:app"]
